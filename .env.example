# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Your numeric Telegram user ID (get from @userinfobot)
ADMIN_USER_ID=123456789

# Path to SQLite database file
# On Railway: set to /data/bot.db and attach a Volume mounted at /data
DATABASE_PATH=./data/bot.db

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Environment: development | production
ENVIRONMENT=development

# Anthropic API key for Claude Haiku summarization (required from Day 3)
ANTHROPIC_API_KEY=

# OpenAI API key for Whisper audio transcription (required from Day 5)
OPENAI_API_KEY=

# Free summaries per user per calendar month
FREE_QUOTA_PER_MONTH=3

# Monthly subscription price in Telegram Stars
SUBSCRIPTION_STARS=500

# Single summary price in Telegram Stars
SINGLE_SUMMARY_STARS=50

# Supadata API key for YouTube transcript fetching (handles cloud/datacenter IPs — recommended)
# Sign up at https://supadata.ai, grab your API key from the dashboard
SUPADATA_API_KEY=

# Proxy for YouTube transcript fetching (fallback when SUPADATA_API_KEY is not set)
# Option A: Webshare rotating residential proxies — https://www.webshare.io
# Sign up, buy a "Residential" plan, grab credentials from dashboard.webshare.io/proxy/settings
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
# Option B: any HTTP/HTTPS proxy URL (e.g. from another provider)
HTTPS_PROXY=
